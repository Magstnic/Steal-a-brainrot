local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VirtualUser = game:GetService("VirtualUser")

local Player = Players.LocalPlayer
local PlayerGui = Player:WaitForChild("PlayerGui")

local Speed = 25
local MoveConnection
local AntiAFK = false

-- نقاط الحركة حول المربعات
local Points = {
	Vector3.new(-331,-4.5,100),
	Vector3.new(-320,-4.5,100),
	Vector3.new(-309,-4.5,100),

	Vector3.new(-309,-4.5,112),

	Vector3.new(-309,-4.5,124),
	Vector3.new(-320,-4.5,124),
	Vector3.new(-331,-4.5,124),

	Vector3.new(-331,-4.5,112),

	Vector3.new(-336,-4.5,95),
	Vector3.new(-304,-4.5,95),
	Vector3.new(-304,-4.5,129),
	Vector3.new(-336,-4.5,129),
}

local CurrentPoint = 1

-- حماية
local function ProtectCharacter(char)
	local hum = char:WaitForChild("Humanoid")

	hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown,false)
	hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll,false)
	hum:SetStateEnabled(Enum.HumanoidStateType.Physics,false)

	hum.HealthChanged:Connect(function()
		if hum.Health < hum.MaxHealth then
			hum.Health = hum.MaxHealth
		end
	end)
end

if Player.Character then
	ProtectCharacter(Player.Character)
end

Player.CharacterAdded:Connect(function(char)
	task.wait(1)
	ProtectCharacter(char)
end)

-- GUI
local Gui = Instance.new("ScreenGui")
Gui.Name = "MandiHub"
Gui.ResetOnSpawn = false
Gui.Parent = PlayerGui

local Frame = Instance.new("Frame")
Frame.Size = UDim2.new(0,240,0,310)
Frame.Position = UDim2.new(1,-260,0,20)
Frame.BackgroundColor3 = Color3.fromRGB(20,12,28)
Frame.Parent = Gui
Frame.Active = true
Frame.Draggable = true

local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1,0,0,35)
Title.Position = UDim2.new(0,0,0,10)
Title.BackgroundTransparency = 1
Title.Text = "Mandi Hub"
Title.TextColor3 = Color3.fromRGB(200,150,255)
Title.Parent = Frame

local Box = Instance.new("TextBox")
Box.Size = UDim2.new(0.85,0,0,40)
Box.Position = UDim2.new(0.075,0,0,85)
Box.Text = "5"
Box.PlaceholderText = "Speed"
Box.Parent = Frame

Box.FocusLost:Connect(function()
	local num = tonumber(Box.Text)
	if num then
		Speed = num
	end
end)

local MoveBtn = Instance.new("TextButton")
MoveBtn.Size = UDim2.new(0.85,0,0,45)
MoveBtn.Position = UDim2.new(0.075,0,0,145)
MoveBtn.Text = "▶ Enable Move"
MoveBtn.Parent = Frame

local moving = false

MoveBtn.MouseButton1Click:Connect(function()
	moving = not moving

	if moving then
		MoveBtn.Text = "■ Auto Collect ON"

		MoveConnection = RunService.Heartbeat:Connect(function()

			local Char = Player.Character
			if not Char then return end

			local Root = Char:FindFirstChild("HumanoidRootPart")
			if not Root then return end

			local target = Points[CurrentPoint] + Vector3.new(0,3,0)
			local dir = target - Root.Position
			local dist = dir.Magnitude

			if dist > 1.5 then
				local step = math.min(Speed / 8, dist)
				local newPos = Root.Position + dir.Unit * step

				Char:PivotTo(CFrame.new(newPos))
			else
				CurrentPoint += 1
				if CurrentPoint > #Points then
					CurrentPoint = 1
				end
			end

		end)

	else
		MoveBtn.Text = "▶ Enable Move"

		if MoveConnection then
			MoveConnection:Disconnect()
			MoveConnection = nil
		end
	end
end)

local AfkBtn = Instance.new("TextButton")
AfkBtn.Size = UDim2.new(0.85,0,0,45)
AfkBtn.Position = UDim2.new(0.075,0,0,210)
AfkBtn.Text = "🛡 Anti-AFK OFF"
AfkBtn.Parent = Frame

AfkBtn.MouseButton1Click:Connect(function()
	AntiAFK = not AntiAFK
	AfkBtn.Text = AntiAFK and "🛡 Anti-AFK ON" or "🛡 Anti-AFK OFF"
end)

Player.Idled:Connect(function()
	if AntiAFK then
		VirtualUser:CaptureController()
		VirtualUser:ClickButton2(Vector2.new())
	end
end)

print("✅ Mandi Hub Final Fixed")
